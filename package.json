{
  "name": "pi-grok-sdk",
  "version": "0.2.0",
  "description": "Pi provider extension that runs Grok through the local xAI agent CLI (ACP by default, streaming-json fallback), with persistent multi-turn sessions similar to pi-cursor-sdk.",
  "type": "module",
  "license": "MIT",
  "author": "Ankit Chouhan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankitchouhan1020/pi-grok-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ankitchouhan1020/pi-grok-sdk/issues"
  },
  "homepage": "https://github.com/ankitchouhan1020/pi-grok-sdk#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "grok",
    "xai",
    "agent",
    "acp",
    "sdk"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  }
}
