{
  "name": "pi-grok-sdk",
  "version": "0.2.1",
  "description": "Use Grok Build inside pi via the local xAI agent CLI — real agent tools, multi-turn ACP sessions, and native thinking/text streaming.",
  "type": "module",
  "license": "MIT",
  "author": "Ankit Chouhan (https://github.com/ankitchouhan1020)",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankitchouhan1020/pi-grok-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ankitchouhan1020/pi-grok-sdk/issues"
  },
  "homepage": "https://github.com/ankitchouhan1020/pi-grok-sdk#readme",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "grok",
    "xai",
    "grok-build",
    "agent",
    "acp",
    "sdk",
    "extension"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  }
}
